// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)

{
  // ─────────────────────────────────────────────────────────────
  // AGENT & AI
  // ─────────────────────────────────────────────────────────────

  "proxy": "",
  "edit_predictions": {
    "ollama": {
      "model": "qwen2.5-coder:7b-base"
    }
  },
  "language_models": {
    "opencode": {
      "show_zen_models": false,
    },
  },

  "agent_servers": {
    "opencode": {
      "default_config_options": {
        "effort": "medium",
        "model": "opencode-go/deepseek-v4-flash",
        "mode": "gentle-orchestrator",
      },
      "type": "registry",
    },
  },

  "agent": {
    "default_profile": "write",
    "show_turn_stats": true,
    "terminal_init_command": "opencode",
    "default_model": {
      "effort": "high",
      "provider": "opencode",
      "model": "go/deepseek-v4-flash",
      "enable_thinking": true,
    },
    "favorite_models": [
      {
        "provider": "opencode",
        "model": "free/big-pickle",
        "enable_thinking": false,
      },
      {
        "provider": "opencode",
        "model": "free/minimax-m3-free",
        "enable_thinking": false,
      },
      {
        "provider": "opencode",
        "model": "free/nemotron-3-ultra-free",
        "enable_thinking": true,
        "effort": "high",
      },
    ],
    "single_file_review": true,
    "play_sound_when_agent_done": "when_hidden",
  },

  // ─────────────────────────────────────────────────────────────
  // APPEARANCE
  // ─────────────────────────────────────────────────────────────

  "theme": "Kanagawa Dragon",
  "icon_theme": "Soft Charmed Icons",

  "tab_bar": {
    "show_nav_history_buttons": false,
    "show_tab_bar_buttons": false,
  },
  "title_bar": {
    "show_menus": true,
    "show_user_menu": false,
    "show_user_picture": false,
    "show_branch_name": false,
    "show_project_items": false,
    "show_onboarding_banner": false,
  },
  "status_bar": {
    "experimental.show": false,
  },
  "toolbar": {
    "code_actions": true,
    "breadcrumbs": false,
    "quick_actions": false,
  },
  "gutter": {
    "bookmarks": false,
    "breakpoints": false,
    "runnables": false,
    "folds": false,
    "min_line_number_digits": 0,
  },
  "scrollbar": {
    "show": "never",
  },
  "minimap": {
    "display_in": "all_editors",
    "show": "always",
  },
  "tabs": {
    "file_icons": true,
    "git_status": true,
  },

  // ─────────────────────────────────────────────────────────────
  // FONTS
  // ─────────────────────────────────────────────────────────────

  "ui_font_family": ".ZedMono",
  "ui_font_size": 16,
  "buffer_font_family": "Iosevka Nerd Font Mono",
  "buffer_font_size": 16,
  "agent_ui_font_size": 16,
  "agent_buffer_font_size": 16,

  // ─────────────────────────────────────────────────────────────
  // EDITOR
  // ─────────────────────────────────────────────────────────────

  "base_keymap": "VSCode",
  "tab_size": 2,
  "multi_cursor_modifier": "cmd_or_ctrl",
  "selection_highlight": false,
  "current_line_highlight": "none",
  "show_whitespaces": "none",
  "horizontal_scroll_margin": 1,
  "vertical_scroll_margin": 1,

  "indent_guides": {
    "coloring": "indent_aware",
    "background_coloring": "indent_aware",
  },

  "colorize_brackets": true,
  "code_lens": "on",

  "inlay_hints": {
    "enabled": true,
  },

  "extend_comment_on_newline": false,
  "seed_search_query_from_cursor": "never",

  "diagnostics": {
    "inline": {
      "enabled": true,
    },
  },

  // ─────────────────────────────────────────────────────────────
  // PANELS
  // ─────────────────────────────────────────────────────────────

  "git_panel": {
    "file_icons": true,
    "tree_view": true,
  },
  "project_panel": {
    "auto_open": {
      "on_drop": false,
      "on_paste": false,
      "on_create": false,
    },
    "indent_guides": {
      "show": "never",
    },
    "default_width": 400,
    "dock": "right",
  },
  "outline_panel": {
    "default_width": 400,
    "indent_guides": {
      "show": "never",
    },
  },
  "file_finder": {
    "modal_max_width": "large",
  },
  "centered_layout": {
    "left_padding": 0.15,
    "right_padding": 0.15,
  },

  // ─────────────────────────────────────────────────────────────
  // COMMAND ALIASES
  // ─────────────────────────────────────────────────────────────

  "command_aliases": {
    "gd": "git::Diff",
    "gb": "git::Branch",
    "gbd": "git::BranchDiff",
    "gp": "git::Push",
    "gcp": "git::CreatePullRequest",
    "tsd": "editor::ToggleSplitDiff",
  },

  // ─────────────────────────────────────────────────────────────
  // AUTOSAVE & SESSIONS
  // ─────────────────────────────────────────────────────────────

  "autosave": "on_window_change",

  "when_closing_with_no_tabs": "platform_default",
  "close_on_file_delete": true,
  "restore_on_file_reopen": false,
  "restore_on_startup": "launchpad",

  "session": {
    "trust_all_worktrees": true,
    "restore_unsaved_buffers": false,
  },

  // ─────────────────────────────────────────────────────────────
  // GIT
  // ─────────────────────────────────────────────────────────────

  "git": {
    "git_gutter": "hide",
    "inline_blame": {
      "padding": 5,
      "enabled": false,
    },
  },
  "file_types": {
    "Git Attributes": ["**/{git,.git,.git/info}/attributes"],
    "Git Config": [
      "*.gitconfig",
      "**/{git,.git,.git/modules,.git/modules/*}/config",
    ],
    "Git Ignore": ["**/{git,.git}/ignore", "**/.git/info/exclude"],
  },

  // ─────────────────────────────────────────────────────────────
  // TERMINAL
  // ─────────────────────────────────────────────────────────────

  "terminal": {
    "copy_on_select": true,
    "font_family": "FiraCode Nerd Font Mono",
    "shell": {
      "program": "zsh",
    },
  },

  // ─────────────────────────────────────────────────────────────
  // LANGUAGE, LANGUAGE SERVERS & FORMATTERS
  // ─────────────────────────────────────────────────────────────

  "lsp": {
    "live-server": {
      "initialization_options": {
        "lazy": true,
        "public": false,
        "start_port": 3000,
      },
    },
    "tailwindcss-language-server": {
      "settings": {
        "includeLanguages": {
          "astro": "html",
        },
        "experimental": {
          "classRegex": [
            "\\.className\\s*[+]?=\\s*['\"]([^'\"]*)['\"]",
            "\\.setAttributeNS\\(.*,\\s*['\"]class['\"],\\s*['\"]([^'\"]*)['\"]",
            "\\.setAttribute\\(['\"]class['\"],\\s*['\"]([^'\"]*)['\"]",
            "\\.classList\\.add\\(['\"]([^'\"]*)['\"]",
            "\\.classList\\.remove\\(['\"]([^'\"]*)['\"]",
            "\\.classList\\.toggle\\(['\"]([^'\"]*)['\"]",
            "\\.classList\\.contains\\(['\"]([^'\"]*)['\"]",
            "\\.classList\\.replace\\([^,)]+,\\s*['\"]([^'\"]*)['\"]",
            "class=\"([^\"]*)\"",
            "class='([^']*)'",
            "class:list=\"{([^}]*)}\"",
            "class:list='{([^']*)}'",
          ],
        },
      },
    },
    "oxlint": {
      "initialization_options": {
        "settings": {
          "configPath": null,
          "run": "onType",
          "disableNestedConfig": false,
          "fixKind": "safe_fix",
          "unusedDisableDirectives": "deny",
        },
      },
    },
    "oxfmt": {
      "initialization_options": {
        "settings": {
          "fmt.configPath": null,
          "run": "onSave",
        },
      },
    },
    "gopls": {
      "initialization_options": {
        "staticcheck": true,
        "analyses": {
          "nilness": true,
          "unusedwrite": true,
          "shadow": true,
          "useany": true,
        },
        "codelenses": {
          "test": true,
          "generate": true,
          "regenerate_cgo": true,
          "tidy": true,
          "upgrade_dependency": true,
          "vendor": true,
        },
        "hints": {
          "assignVariableTypes": true,
          "compositeLiteralFields": true,
          "compositeLiteralTypes": true,
          "constantValues": true,
          "functionTypeParameters": true,
          "parameterNames": true,
          "rangeVariableTypes": true,
        },
      },
    },
    "golangci-lint": {
      "initialization_options": {
        "command": [
          "golangci-lint",
          "run",
          "--output.json.path",
          "stdout",
          "--show-stats=false",
          "--output.text.path=",
        ],
      },
    },
    "rust-analyzer": {
      "initialization_options": {
        "rust": {
          "analyzerTargetDir": true,
        },
        "inlayHints": {
          "maxLength": null,
          "lifetimeElisionHints": {
            "enable": "skip_trivial",
            "useParameterNames": true,
          },
          "closureReturnTypeHints": {
            "enable": "always",
          },
        },
      },
    },
  },

  "languages": {
    "JavaScript": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false,
      },
      "language_servers": [
        "typescript-language-server",
        "oxlint",
        "emmet-language-server",
        "autocorrect",
        "codebook",
      ],
      "formatter": [
        {
          "language_server": { "name": "oxfmt" },
        },
        { "code_action": "source.fixAll.oxc" },
      ],
    },
    "TypeScript": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false,
      },
      "language_servers": [
        "typescript-language-server",
        "oxlint",
        "emmet-language-server",
        "autocorrect",
        "codebook",
      ],
      "formatter": [
        {
          "language_server": { "name": "oxfmt" },
        },
      ],
    },
    "TSX": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false,
      },
      "language_servers": [
        "typescript-language-server",
        "oxlint",
        "emmet-language-server",
        "autocorrect",
        "codebook",
      ],
      "formatter": [
        {
          "language_server": { "name": "oxfmt" },
        },
      ],
    },
    "HTML": {
      "format_on_save": "on",
      "language_servers": [
        "vscode-html-language-server",
        "emmet-language-server",
        "live-server",
        "autocorrect",
        "codebook",
      ],
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"],
        },
      },
    },
    "CSS": {
      "format_on_save": "on",
      "language_servers": [
        "tailwindcss-intellisense-css",
        "emmet-language-server",
        "autocorrect",
        "codebook",
      ],
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"],
        },
      },
    },
    "JSON": {
      "format_on_save": "on",
      "language_servers": ["autocorrect", "codebook"],
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--stdin-filepath", "{buffer_path}"],
        },
      },
    },
    "SQL": {
      "language_servers": ["autocorrect", "codebook"],
    },
    "Go": {
      "language_servers": ["gopls", "golangci-lint", "autocorrect", "codebook"],
      "inlay_hints": {
        "enabled": true,
      },
    },
    "Rust": {
      "language_servers": ["rust-analyzer", "autocorrect", "codebook"],
    },
  },

  "auto_install_extensions": {
    "kanagawa-themes": true,
    "charmed-icons": true,
    "html": true,
    "xml": true,
    "astro": true,
    "git-firefly": true,
    "sql": true,
    "oxc": true,
    "golangci-lint": true,
    "live-server": true,
    "live-template": true,
    "autocorrect": true,
    "comment": true,
    "emmet": true,
  },
  "auto_update_extensions": {
    "kanagawa-themes": true,
    "charmed-icons": true,
    "html": true,
    "xml": true,
    "astro": true,
    "git-firefly": true,
    "sql": true,
    "biome": true,
    "oxc": true,
    "golangci-lint": true,
    "live-server": true,
    "live-template": true,
    "autocorrect": true,
    "comment": true,
    "emmet": true,
  },

  // ─────────────────────────────────────────────────────────────
  // TELEMETRY
  // ─────────────────────────────────────────────────────────────

  "telemetry": {
    "diagnostics": true,
    "metrics": false,
  },
}
